{
  "name": "justin-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run catalog:validate && npm run validate:projects && npm run validate:target-demo-media && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "catalog:scan": "tsx scripts/catalog/scan-projects.ts",
    "catalog:validate": "tsx scripts/catalog/sync-catalog.ts",
    "catalog:sync": "npm run catalog:scan && npm run catalog:validate",
    "release:projects": "tsx scripts/portfolio-release/process-project-releases.ts",
    "quality:projects": "tsx scripts/portfolio-release/run-project-quality-pass.ts",
    "media:posters": "tsx scripts/portfolio-release/generate-video-posters.ts",
    "audit:project-demos": "tsx scripts/validate-project-demos.ts --write",
    "validate:project-demos": "tsx scripts/validate-project-demos.ts",
    "deploy:project-demos": "tsx scripts/portfolio-release/deploy-project-demos.ts",
    "deploy:real-app-demos": "tsx scripts/portfolio-release/deploy-real-web-app-demos.ts",
    "remediate:original-app-demos": "tsx scripts/portfolio-release/remediate-original-app-demos.ts",
    "portfolio:implement-target-demos": "tsx scripts/portfolio-release/implement-target-demo-sites.ts",
    "validate:target-demo-media": "tsx scripts/validate-target-demo-media.ts",
    "deploy:static-project-demos": "tsx scripts/portfolio-release/deploy-static-project-demos.ts",
    "validate:static-demos": "tsx scripts/validate-static-demos.ts",
    "deploy": "bash scripts/deploy.sh",
    "validate:projects": "tsx scripts/validate-project-links.ts",
    "postbuild": "tsx scripts/create-github-pages-legacy-redirects.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
